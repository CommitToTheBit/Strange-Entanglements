{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "configure (debug)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"-S",
				".",
				"-B",
				"./build/windows/debug",
				"-G",
				"Ninja",
				"-DCMAKE_BUILD_TYPE=Debug",
				"-DCMAKE_C_COMPILER=clang-cl",
				"-DCMAKE_CXX_COMPILER=clang-cl"
			],
			"problemMatcher": []
		},
		{
			"label": "configure (release)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"-S",
				".",
				"-B",
				"./build/windows/release",
				"-G",
				"Ninja",
				"-DCMAKE_BUILD_TYPE=RelWithDebInfo",
				"-DCMAKE_C_COMPILER=clang-cl",
				"-DCMAKE_CXX_COMPILER=clang-cl"
			],
			"problemMatcher": []
		},
		{
			"label": "configure (goldmaster)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"-S",
				".",
				"-B",
				"./build/windows/goldmaster",
				"-G",
				"Ninja",
				"-DCMAKE_BUILD_TYPE=Release",
				"-DCMAKE_C_COMPILER=clang-cl",
				"-DCMAKE_CXX_COMPILER=clang-cl"
			],
			"problemMatcher": []
		},
