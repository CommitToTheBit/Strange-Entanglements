				"merge profile data (goldmaster-csir-pgo)"
			],
			"problemMatcher": []
		},
		{
			"label": "merge profile data (goldmaster-pgo)",
			"type": "shell",
			"command": "llvm-profdata",
			"args": [
				"merge",
				"--output=build/windows/goldmaster/pgo/pgo.profdata",
				"build/windows/goldmaster/pgo/pgo-instr.profraw"
			],
			"problemMatcher": []
		},
		{
			"label": "merge profile data (goldmaster-ir-pgo)",
			"type": "shell",
			"command": "llvm-profdata",
			"args": [
				"merge",
				"--output=build/windows/goldmaster/pgo/ir-pgo.profdata",
				"build/windows/goldmaster/pgo/ir-pgo-instr.profraw"
			],
			"problemMatcher": []
		},
		{
			"label": "merge profile data (goldmaster-csir-pgo)",
			"type": "shell",
			"command": "llvm-profdata",
			"args": [
				"merge",
				"--output=build/windows/goldmaster/pgo/csir-pgo.profdata",
				"build/windows/goldmaster/pgo/ir-pgo.profdata",
				"build/windows/goldmaster/pgo/csir-pgo-instr.profraw"
			],
			"problemMatcher": []
		},
		{
			"label": "build (debug)",
			"type": "shell",
			"command": "ninja",
			"args": [
				"-C",
				"build/windows/debug"
			],
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"problemMatcher": "$clang"
		},
		{
			"label": "build (release)",
			"type": "shell",
			"command": "ninja",
			"args": [
				"-C",
				"build/windows/release"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$clang"
		},
		{
			"label": "build (goldmaster)",
			"type": "shell",
			"command": "ninja",
			"args": [
				"-C",
				"build/windows/goldmaster"
			],
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"problemMatcher": "$clang"
