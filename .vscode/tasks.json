				"-S",
				".",
				"-B",
				"./build/windows/goldmaster",
				"-G",
				"Ninja",
				"-DCMAKE_BUILD_TYPE=Release",
				"-DCMAKE_C_COMPILER=clang-cl",
				"-DCMAKE_CXX_COMPILER=clang-cl",
