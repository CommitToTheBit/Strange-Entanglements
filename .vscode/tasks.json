			"problemMatcher": []
		},
		{
			"label": "configure (goldmaster-csir-pgo)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"-S",
				".",
				"-B",
				"./build/windows/goldmaster",
				"-G",
				"Ninja",
				"-DCMAKE_BUILD_TYPE=Release",
				"-DCMAKE_C_COMPILER=clang-cl",
